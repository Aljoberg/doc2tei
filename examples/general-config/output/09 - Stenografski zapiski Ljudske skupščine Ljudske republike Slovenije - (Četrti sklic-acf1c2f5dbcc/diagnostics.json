    },
    {
      "text": "Pričenjam 13. sejo Republiškega zbora Ljudske skupščine LRS, ki jo je sklical",
      "x": 33.84,
      "y": 384.93,
      "page": 5,
      "font_size": 9.0,
      "line_text": "Pričenjam 13. sejo Republiškega zbora Ljudske skupščine LRS, ki jo je sklical"
    },
    {
      "text": "predsednik Ljudske skupščine LRS. Zapisnik današnje seje bo vodil Drago",
      "x": 33.36,
      "y": 374.61,
      "page": 5,
      "font_size": 9.0,
      "line_text": "predsednik Ljudske skupščine LRS. Zapisnik današnje seje bo vodil Drago"
    },
    {
      "text": "Seliger.",
      "x": 33.12,
      "y": 365.97,
      "page": 5,
      "font_size": 9.0,
      "line_text": "Seliger."
    },
    {
      "text": "in Slavica Zirkelbach so opravičili svojo odsotnost.",
      "x": 32.88,
      "y": 341.73,
      "page": 5,
      "font_size": 9.0,
      "line_text": "in Slavica Zirkelbach so opravičili svojo odsotnost."
    },
    {
      "text": "(Zapisnikar ljudski poslanec Stane Sotlar prečita zapisnik 12. seje.)",
      "x": 33.12,
      "y": 320.85,
      "page": 5,
      "font_size": 9.0,
      "line_text": "(Zapisnikar ljudski poslanec Stane Sotlar prečita zapisnik 12. seje.)"
    },
    {
      "text": "nihče.) Ce nihče, ugotavljam, da je zapisnik odobren in da se ga lahko podpiše.",
      "x": 32.64,
      "y": 299.97,
      "page": 5,
      "font_size": 9.0,
      "line_text": "nihče.) Ce nihče, ugotavljam, da je zapisnik odobren in da se ga lahko podpiše."
    },
    {
      "text": "(Predsednik in zapisnikar podpišeta zapisnik.)",
      "x": 32.88,
      "y": 289.89,
      "page": 5,
      "font_size": 9.0,
      "line_text": "(Predsednik in zapisnikar podpišeta zapisnik.)"
    },
    {
      "text": "ložil poročilo o uvajanju vzpodbudnih oblik razdeljevanja osebnih dohodkov",
      "x": 31.92,
      "y": 269.01,
      "page": 5,
      "font_size": 9.0,
      "line_text": "ložil poročilo o uvajanju vzpodbudnih oblik razdeljevanja osebnih dohodkov"
    },
    {
      "text": "v gospodarskih organizacijah in o strokovnem izobraževanju v zvezi s produk",
      "x": 31.92,
      "y": 258.45,
      "page": 5,
      "font_size": 9.0,
      "line_text": "v gospodarskih organizacijah in o strokovnem izobraževanju v zvezi s produk"
    },
    {
      "text": "tivnostjo dela. Odbori, ki so to poročilo obravnavali pa predlagajo v zvezi z njim",
      "x": 31.68,
      "y": 248.37,
      "page": 5,
      "font_size": 9.0,
      "line_text": "tivnostjo dela. Odbori, ki so to poročilo obravnavali pa predlagajo v zvezi z njim"
    },
    {
      "text": "resolucijo. Odbor za presveto in kulturo je pripravil poročilo o svojem pri",
      "x": 31.68,
      "y": 237.81,
      "page": 5,
      "font_size": 9.0,
      "line_text": "resolucijo. Odbor za presveto in kulturo je pripravil poročilo o svojem pri"
    },
    {
      "text": "poročilu.",
      "x": 31.44,
      "y": 228.69,
      "page": 5,
      "font_size": 9.0,
      "line_text": "poročilu."
    },
    {
      "text": "Izvršni svet predlagam za današnjo sejo naslednji dnevni red:",
      "x": 30.96,
      "y": 204.69,
      "page": 5,
      "font_size": 9.0,
      "line_text": "Izvršni svet predlagam za današnjo sejo naslednji dnevni red:"
    },
    {
      "text": "dohodkov v gospodarskih organizacijah in o strokovnem izobraževanju v zvezi",
      "x": 30.72,

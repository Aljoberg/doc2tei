    },
    {
      "text": "Pričenjam 7. sejo Republiškega zbora Ljudsko skupščine Ljudske republike",
      "x": 19.92,
      "y": 424.29,
      "page": 5,
      "font_size": 9.0,
      "line_text": "Pričenjam 7. sejo Republiškega zbora Ljudsko skupščine Ljudske republike"
    },
    {
      "text": "Slovenije, ki jo je sklical predsednik Ljudske skupščine Ljudske republike",
      "x": 19.92,
      "y": 413.49,
      "page": 5,
      "font_size": 9.0,
      "line_text": "Slovenije, ki jo je sklical predsednik Ljudske skupščine Ljudske republike"
    },
    {
      "text": "Slovenije. Zapisnik današnje seje bo vodila tovarišica Slavica Zirkelbach.",
      "x": 19.92,
      "y": 402.93,
      "page": 5,
      "font_size": 9.0,
      "line_text": "Slovenije. Zapisnik današnje seje bo vodila tovarišica Slavica Zirkelbach."
    },
    {
      "text": "Angela Ocepek, Ivan Rančigaj, Ivan Regent, Lojzka Stropnik, Mira Svetina, Jože",
      "x": 20.16,
      "y": 381.57,
      "page": 5,
      "font_size": 9.0,
      "line_text": "Angela Ocepek, Ivan Rančigaj, Ivan Regent, Lojzka Stropnik, Mira Svetina, Jože"
    },
    {
      "text": "Tramšek, Maks Vale in inž. Pavle Zaucer. Ali jim zbor odsotnost opraviči?",
      "x": 19.92,
      "y": 370.77,
      "page": 5,
      "font_size": 9.0,
      "line_text": "Tramšek, Maks Vale in inž. Pavle Zaucer. Ali jim zbor odsotnost opraviči?"
    },
    {
      "text": "(Poslanci se strinjajo.) Ker se zbor strinja, ugotavljarn, da je omenjenim po",
      "x": 20.64,
      "y": 360.21,
      "page": 5,
      "font_size": 9.0,
      "line_text": "(Poslanci se strinjajo.) Ker se zbor strinja, ugotavljarn, da je omenjenim po"
    },
    {
      "text": "slancem odsotnost opravičena.",
      "x": 19.92,
      "y": 349.41,
      "page": 5,
      "font_size": 9.0,
      "line_text": "slancem odsotnost opravičena."
    },
    {
      "text": "pisnik G. seje. (Zapisnikar Drago Seliger prebere zapisnik 6. seje.)",
      "x": 20.4,
      "y": 327.81,
      "page": 5,
      "font_size": 9.0,
      "line_text": "pisnik G. seje. (Zapisnikar Drago Seliger prebere zapisnik 6. seje.)"
    },
    {
      "text": "nihče.) Ker nihče, menim, da je zapisnik odobren in da se lahko podpiše.",
      "x": 20.88,
      "y": 305.97,
      "page": 5,
      "font_size": 9.0,
      "line_text": "nihče.) Ker nihče, menim, da je zapisnik odobren in da se lahko podpiše."
    },
    {
      "text": "(Predsedujoči Milan Apih in zapisnikar Drago Seliger podpišeta zapisnik.)",
      "x": 20.88,
      "y": 295.41,
      "page": 5,
      "font_size": 9.0,
      "line_text": "(Predsedujoči Milan Apih in zapisnikar Drago Seliger podpišeta zapisnik.)"
    },

      "x": 45.36,
      "y": 354.47,
      "page": 5,
      "font_size": 10.0,
      "line_text": "44. člena začasnega poslovnika našega zbora. "
    },
    {
      "text": "novič, inž. Ivica Kavčič, Franc Klobučar, inž. Viktor Kotnik in France Popit. ",
      "x": 45.6,
      "y": 333.59,
      "page": 5,
      "font_size": 10.0,
      "line_text": "novič, inž. Ivica Kavčič, Franc Klobučar, inž. Viktor Kotnik in France Popit. "
    },
    {

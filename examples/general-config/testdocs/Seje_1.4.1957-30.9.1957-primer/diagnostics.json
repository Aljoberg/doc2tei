      "line_text": "/) 18. И. 1958"
    },
    {
      "text": "jo je po 60. členu ustavnega zakona ter 19. členu poslovnika Republiškega",
      "x": 18.96,
      "y": 394.31,
      "page": 5,
      "font_size": 10.0,
      "line_text": "jo je po 60. členu ustavnega zakona ter 19. členu poslovnika Republiškega"
    },
    {
      "text": "zbora sklical predsednik Ljudske skupščine Ljudske republike Slovenije.",
      "x": 18.72,
      "y": 383.51,
      "page": 5,
      "font_size": 10.0,
      "line_text": "zbora sklical predsednik Ljudske skupščine Ljudske republike Slovenije."
    },
    {
      "text": "Julij Beltram, Boris Kocijančič, Franc Krese, Tone Zupančič, Karel Štrukelj,",
      "x": 18.96,
      "y": 350.63,
      "page": 5,
      "font_size": 10.0,
      "line_text": "Julij Beltram, Boris Kocijančič, Franc Krese, Tone Zupančič, Karel Štrukelj,"
    },
    {
      "text": "Stanko Brečko, Alojz Lukač, Ivan Rančigaj in Nerino Gobbo. Predlagam, da",
      "x": 18.96,
      "y": 340.07,
      "page": 5,
      "font_size": 10.0,
      "line_text": "Stanko Brečko, Alojz Lukač, Ivan Rančigaj in Nerino Gobbo. Predlagam, da"
    },
    {
      "text": "jim zbor opraviči odsotnost. Se tovariši poslanci strinjate s tem predlogom?",
      "x": 18.96,
      "y": 329.27,
      "page": 5,
      "font_size": 10.0,
      "line_text": "jim zbor opraviči odsotnost. Se tovariši poslanci strinjate s tem predlogom?"
    },
    {
      "text": "(Poslanci se strinjajo.) Ker se zbor strinja s tem predlogom, je imenovanim",
      "x": 18.96,
      "y": 318.71,
      "page": 5,
      "font_size": 10.0,
      "line_text": "(Poslanci se strinjajo.) Ker se zbor strinja s tem predlogom, je imenovanim"
    },
    {
      "text": "za to sejo odsotnost opravičena.",
      "x": 18.96,
      "y": 307.91,
      "page": 5,
      "font_size": 10.0,
      "line_text": "za to sejo odsotnost opravičena."
    },
    {
      "text": "seje. (Zapisnikar Dušan Bole prebere zapisnik 18. seje.) Ima kdo od tovarišev",
      "x": 18.96,
      "y": 286.07,
      "page": 5,
      "font_size": 10.0,
      "line_text": "seje. (Zapisnikar Dušan Bole prebere zapisnik 18. seje.) Ima kdo od tovarišev"
    },
    {
      "text": "poslancev kakšno pripombo k zapisniku? (Ne javi se nihče.) Ker ni pripomb,",
      "x": 19.2,
      "y": 275.51,
      "page": 5,
      "font_size": 10.0,
      "line_text": "poslancev kakšno pripombo k zapisniku? (Ne javi se nihče.) Ker ni pripomb,"
    },
    {
      "text": "menim, da je zapisnik odobren in da se lahko podpiše. (Predsednik in zapisnikar",
      "x": 18.96,
      "y": 264.95,
      "page": 5,
      "font_size": 10.0,
      "line_text": "menim, da je zapisnik odobren in da se lahko podpiše. (Predsednik in zapisnikar"
    },
    {
      "text": "podpišeta zapisnik.)",
      "x": 19.44,
      "y": 254.39,
      "page": 5,
      "font_size": 10.0,
      "line_text": "podpišeta zapisnik.)"
    },
    {
      "text": "republike Slovenije v obravnavo predlog zakona o spremembah zakona o",
      "x": 19.44,
      "y": 232.55,
      "page": 5,
      "font_size": 10.0,
      "line_text": "republike Slovenije v obravnavo predlog zakona o spremembah zakona o"
    },
    {
      "text": "gozdovih, o spremembah in dopolnitvah zakona o gozdnih skladih; Izvršni svet",
      "x": 19.2,
      "y": 221.75,
      "page": 5,
      "font_size": 10.0,
      "line_text": "gozdovih, o spremembah in dopolnitvah zakona o gozdnih skladih; Izvršni svet"
    },
    {
      "text": "je poslal poročilo o svojem delu za leto 1956 ter predlagal, da se na tem zase",
      "x": 19.2,
      "y": 210.95,
      "page": 5,
      "font_size": 10.0,
      "line_text": "je poslal poročilo o svojem delu za leto 1956 ter predlagal, da se na tem zase"
    },
    {
      "text": "danju obenem s predloženimi zakoni obravnava referat o organizaciji gozdar",
      "x": 19.44,
      "y": 200.39,
      "page": 5,
      "font_size": 10.0,
      "line_text": "danju obenem s predloženimi zakoni obravnava referat o organizaciji gozdar"
    },
    {
      "text": "stva; mandatno-imunitetni odbor ima predlog glede potrditve mandata na",
      "x": 19.44,
